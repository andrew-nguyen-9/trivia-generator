# Pipeline (service role — NEVER expose to the frontend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# TMDB — free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Frontend (frontend/.env.local — anon/public, read-only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps JS API — optional; enables satellite map in The Map room.
# Get a key at https://console.cloud.google.com (Maps JavaScript API, restrict to your domain).
# Without this the room uses the offline SVG world map instead.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
