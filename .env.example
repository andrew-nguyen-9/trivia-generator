# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Pipeline writes (service-role-equivalent: a Neon role with INSERT/UPDATE).
# Get a free connection string at https://neon.tech → project → Connection Details.
# Leave blank to run DB-less (the repo's bronze layer is the database).
DATABASE_URL=

# Frontend reads (frontend/.env.local). Use a READ-ONLY Neon role here — it runs
# in Server Components at build/revalidate time, never shipped to the browser.
# Same value works; a dedicated read-only role is recommended for least privilege.
# DATABASE_URL=

# TMDB — free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Supabase (Realtime + leaderboard only) ────────────────────────────────
# Question reads moved to Neon (above). Supabase is still used for two live
# features: The Lobby (Realtime Broadcast) and the optional global leaderboard
# (submit-score Edge Function). Leave blank to keep the Lobby in offline-notice
# mode and scores device-local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps JS API — optional; enables satellite map in The Map room.
# Get a key at https://console.cloud.google.com (Maps JavaScript API).
# Without this the room uses the offline SVG world map instead.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
