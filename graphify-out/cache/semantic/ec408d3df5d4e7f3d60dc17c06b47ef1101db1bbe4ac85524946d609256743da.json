{"nodes": [{"id": "docs_research_trivia_sources", "label": "RESEARCH_TRIVIA_SOURCES \u2014 Source Survey & Forge Design", "file_type": "document", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "1-165", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_fact_question_forge", "label": "Fact\u2192Question Forge Pattern", "file_type": "rationale", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "116-150", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Scraping facts (structured: subject, year, numeric_value, image_url) instead of questions lets one fact fuel multiple game modes. The forge derives typed questions (multiple_choice, year_guess, higher_lower, clue) from the same atomic fact, with difficulty derived from the popularity signal percentile."}, {"id": "concept_sibling_sampling_distractors", "label": "Sibling Sampling for Distractor Generation", "file_type": "rationale", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "137-149", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multiple-choice distractors come from sibling facts: same category, same answer field, within \u00b11 difficulty band. Type-consistent and plausibility-banded. Wikidata SPARQL can generate these from structured triples (Phase 2 upgrade path)."}, {"id": "concept_difficulty_from_popularity", "label": "Difficulty Score from Popularity Percentile", "file_type": "rationale", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "143-147", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Difficulty (1-5 scale) is derived from the percentile of the source popularity signal (Wikipedia pageviews, Deezer nb_fan, TMDB popularity) within its category. This makes Jeopardy row values ($200-$1000) fall out automatically and keeps difficulty data-driven rather than hand-labeled."}, {"id": "source_wikipedia", "label": "Wikipedia REST API \u2014 Trivia Source", "file_type": "concept", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "29-46", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "source_deezer", "label": "Deezer API \u2014 Trivia Source", "file_type": "concept", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "51-63", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "source_sleeper_espn", "label": "Sleeper + ESPN APIs \u2014 Sports Trivia Source", "file_type": "concept", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "65-76", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "source_tmdb", "label": "TMDB API \u2014 Screen Trivia Source", "file_type": "concept", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "78-89", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "source_restcountries", "label": "restcountries \u2014 Geography Trivia Source", "file_type": "concept", "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "107-111", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_research_trivia_sources", "target": "concept_fact_question_forge", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "116-150", "weight": 1.0}, {"source": "docs_research_trivia_sources", "target": "concept_sibling_sampling_distractors", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/RESEARCH_TRIVIA_SOURCES.md", "source_location": "137-149", "weight": 1.0}, {"source": "docs_research_trivia_sources", "target": "concept_difficulty_from_popularity", "relation": "references", "confidence": "EX